{
  "name": "splog",
  "description": "A simple Single Page Blog...",
  "version": "1.0.0",
  "author": "brine",
  "license": "MIT",
  "main": "index.html",
  "splog": {
    "url": "http://lvh.me:4242/",
    "pathToIndex": "./src/data/siteIndex.json",
    "pathToPostsFolder": "./assets/posts",
    "pathToRssFolder": "./assets/rss",
    "maxPosts": "7"
  },
  "standard": {
    "globals": [
      "t",
      "fixture",
      "test",
      "throw"
    ]
  },
  "scripts": {
    "test": "testcafe chrome e2e/tests/",
    "headless": "testcafe chrome:headless e2e/tests/",
    "testcafe": "testcafe",
    "pretty": "npx standard --fix .",
    "pack": "webpack",
    "rss": "./node_modules/.bin/babel-node src/lib/genr8Blog.js",
    "pod": "./node_modules/.bin/babel-node src/lib/genr8Pod.js",
    "build:index": "./node_modules/.bin/babel-node src/lib/genr8Index.js",
    "prestart": "pkill -f http-server",
    "start": "npm run build:index && npm run rss && npm run pod && npm run pack",
    "server:prod": "http-server ./ -p 80 & exit",
    "server": "http-server -p 4242"
  },
  "dependencies": {
    "showdown": "^1.9.0",
    "testcafe": "^1.15.0",
    "webpack": "^5.2.0",
    "webpack-cli": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.11.4",
    "@babel/node": "^7.10.5",
    "@babel/plugin-proposal-object-rest-spread": "^7.11.0",
    "@babel/plugin-proposal-throw-expressions": "^7.10.4",
    "@babel/plugin-transform-runtime": "^7.11.5",
    "@babel/preset-env": "^7.11.0",
    "babel-jest": "^27.3.1",
    "http-server": "^14.0.0",
    "jest": "^27.3.1"
  }
}
